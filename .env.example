# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fintech_db

# Google Gemini
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-2.5-flash

# Redis
REDIS_URL=redis://localhost:6379

# App
LOG_LEVEL=INFO
DEBUG=false
APP_NAME=AI Fintech Platform
APP_VERSION=0.1.0

# DB pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Cache TTL (seconds)
CACHE_TTL_SECONDS=3600

# Market sizing defaults
MARKET_RADIUS_DEFAULT_M=1000
MARKET_CITY_RADIUS_M=15000
